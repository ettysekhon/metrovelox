#!/usr/bin/env bash
# OpenVelox Environment Configuration
# =====================================
# Copy to env.sh and fill in your values:
#   cp env.sh.template env.sh
#   vim env.sh
#   source env.sh

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────
export ENV="prod"  # prod | dev | staging

# ─────────────────────────────────────────────────────────────────────────────
# GCP CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
export PROJECT_ID="openvelox-elt-01"
export PROJECT_NUMBER=""  # Auto-filled by bootstrap
export REGION="europe-west2"
export ZONE="europe-west2-a"
export BILLING_ACCOUNT_ID=""  # From: gcloud billing accounts list

# ─────────────────────────────────────────────────────────────────────────────
# CLUSTER
# ─────────────────────────────────────────────────────────────────────────────
export GKE_CLUSTER_NAME="openvelox"
# Zonal cluster — use --zone (not --region) with: gcloud container clusters get-credentials
export GKE_SPOT_MACHINE_TYPE="e2-standard-8"
export GKE_STANDARD_MACHINE_TYPE="e2-medium"

# ─────────────────────────────────────────────────────────────────────────────
# DOMAIN & DNS
# ─────────────────────────────────────────────────────────────────────────────
export DOMAIN="mydomain.com"
export CLOUDFLARE_API_TOKEN=""  # Create at: dash.cloudflare.com/profile/api-tokens
export CLOUDFLARE_ZONE_ID=""    # From domain overview page

# ─────────────────────────────────────────────────────────────────────────────
# EXTERNAL API KEYS
# ─────────────────────────────────────────────────────────────────────────────
export TFL_API_KEY=""           # From: api-portal.tfl.gov.uk
export GEMINI_API_KEY=""        # From: aistudio.google.com/apikey
export TIMEGPT_API_KEY=""       # From: dashboard.nixtla.io (optional)

# ─────────────────────────────────────────────────────────────────────────────
# GITHUB (for ArgoCD repo + Airflow GitDagBundle)
# ─────────────────────────────────────────────────────────────────────────────
export GITHUB_ORG="your-org"
export GITHUB_REPO="openvelox"
export GITHUB_PAT=""            # From: https://github.com/settings/personal-access-tokens

# ─────────────────────────────────────────────────────────────────────────────
# TERRAFORM STATE
# ─────────────────────────────────────────────────────────────────────────────
export TF_STATE_BUCKET="tfstate-${PROJECT_ID}"

# ─────────────────────────────────────────────────────────────────────────────
# DERIVED (do not edit)
# ─────────────────────────────────────────────────────────────────────────────
export ARTIFACT_REGISTRY="${REGION}-docker.pkg.dev/${PROJECT_ID}/openvelox"
export KUBECONFIG="${HOME}/.kube/config-${PROJECT_ID}"
export GCS_BUCKET="${PROJECT_ID}-lakehouse"
