# OpenVelox — Public (non-secret) configuration
#
# This file is COMMITTED to Git.  It contains the values that get substituted
# into *.tmpl.yaml manifests by scripts/render-manifests.sh to produce the
# matching *.yaml files that ArgoCD and Kustomize read.
#
# To fork openvelox for your own deployment:
#   1. Edit the values below (domain, GitHub org/repo).
#   2. Run:   scripts/render-manifests.sh
#   3. Commit both config.env and the regenerated *.yaml files.
#   4. Push and let ArgoCD pick up the changes.
#
# Secret values (API tokens, PATs, passwords) do NOT belong here — keep
# those in env.sh (gitignored) or Vault.

DOMAIN=metrovelox.com
GITHUB_ORG=ettysekhon
GITHUB_REPO=openvelox
